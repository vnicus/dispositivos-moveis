<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.CadastroProduto"
             Title="Cadastro Produto">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" 
                     Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <VerticalStackLayout>

            <Label Text="Descrição do Produto:"/>
            <Entry x:Name="txt_descricao" Text="{Binding Descricao}"/>
            
            <Label Text="Quantidade:"/>
            <Entry x:Name="txt_quantidade" Keyboard="Numeric" Text="{Binding Quantidade}"/>
            
            <Label Text="Preço:"/>
            <Entry x:Name="txt_preco" Keyboard="Numeric" Text="{Binding Preco}"/>
            
        </VerticalStackLayout>
    </ContentPage.Content>
    
</ContentPage>