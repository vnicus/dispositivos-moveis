<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ConfirmarEmail"
             Title="ConfirmarEmail">

    <VerticalStackLayout Margin="10" Spacing="10">
        
        <Label Text="Redefinir senha" 
               TextColor="{StaticResource Primary}"
               HorizontalTextAlignment="Center" 
               FontSize="20"
               FontAttributes="Bold"
               FontFamily="IosevkaCharonMonoBold"/>
        
        <Label Text="Informe seu E-mail para que seja encaminhado um código para redefinição da sua senha."/>

        <Border Padding="5" StrokeShape="RoundRectangle 10">

            <VerticalStackLayout Spacing="5">

                <HorizontalStackLayout Spacing="10">

                    <Label Text="E-mail"/>
                    <Entry Placeholder="email@exemplo.com" x:Name="ent_email" />

                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Border>

        <Button Text="Enviar codigo" Clicked="Button_Clicked"/>
            
    </VerticalStackLayout>
</ContentPage>