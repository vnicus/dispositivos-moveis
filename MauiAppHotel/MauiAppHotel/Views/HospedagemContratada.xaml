<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             Title="HospedagemContratada">
    
    <VerticalStackLayout Margin="10" Spacing="10">

        <Label Text="{Binding QuartoSelecionado.Descricao}"
               TextColor="{StaticResource Primary}"
               HorizontalTextAlignment="Center" 
               FontSize="20"
               FontAttributes="Bold"
               FontFamily="IosevkaCharonMonoBold"/>
        
        <Border Padding="5" StrokeShape="RoundRectangle 10">
            
            <StackLayout Spacing="5">
                
                <Border Padding="10" StrokeShape="RoundRectangle 10">
                    <StackLayout Orientation="Horizontal" Spacing="15">
                        
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Adultos: "/>
                            <Label Text="{Binding QntAdultos}" 
                                   TextColor="{StaticResource Primary}"/>
                        </HorizontalStackLayout>
                        
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Crianças: "/>
                            <Label Text="{Binding QntCriancas}" 
                                   TextColor="{StaticResource Primary}" />
                        </HorizontalStackLayout>
                        
                    </StackLayout>
                </Border>

                <Border Padding="10" StrokeShape="RoundRectangle 10">
                    <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="Auto, Auto">
                        <Label Grid.Column="0" Grid.Row="0" Text="Check-in: "/>
                        <Label Grid.Column="1" Grid.Row="0" Text="Check-Out: "/>
                        <Label Grid.Column="2" Grid.Row="0" Text="Estadia: "/>

                        <Label Grid.Column="0" Grid.Row="1"
                       TextColor="{StaticResource Primary}"
                       Text="{Binding DataCheckin, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                        <Label Grid.Column="1" Grid.Row="1"
                       TextColor="{StaticResource Primary}"
                       Text="{Binding DataCheckout, StringFormat='{}{0:dd/MM/yyyy}'}"/>

                        <Label Grid.Column="3" Grid.Row="1"
                       TextColor="{StaticResource Primary}"
                       Text="{Binding Estadia}"/>
                    </Grid>
                </Border>
                <Border Padding="10" StrokeShape="RoundRectangle 10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Valor Total:" />
                        <Label Text="{Binding ValorTotal, StringFormat='{}{0:c}'}"                      
                       TextColor="{StaticResource Primary}" />
                    </HorizontalStackLayout>
                </Border>
                
            </StackLayout>
        </Border>
        <Button Text="Voltar a tela Inicial" Clicked="Button_Clicked"/>

    </VerticalStackLayout>
</ContentPage>