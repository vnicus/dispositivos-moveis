<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="ContratacaoHospedagem">

	<!-- Container geral da Tela -->
	<VerticalStackLayout Padding="10" Spacing="10">
		<Label Text="Cálculo da Diária"
			   TextColor="{StaticResource Primary}"
				HorizontalTextAlignment="Center" 
				FontSize="20"
				FontAttributes="Bold"
				FontFamily="IosevkaCharonMonoBold"/>

		<Label x:Name="txt_usuario_logado" 
			   IsVisible="False"/>
		<Button x:Name="btn_sair" 
				Text="Deslogar" 
				IsVisible="False" 
				Clicked="btn_sair_Clicked"/>

		<Grid ColumnDefinitions="*, *" ColumnSpacing="5">
			<Button Text="Login"  Grid.Column="0" Clicked="Button_Login"/>
			<Button Text="Cadastro"  Grid.Column="1" Clicked="Button_Cadastrar"/>
		</Grid>
		
		<Button Text="Redefinir Senha" Clicked="Button_Redefinir_Senha"/>

        <!-- Container das quantidades de pessoas e escolha do quarto -->
		<Border Padding="10" StrokeShape="RoundRectangle 10">
			<VerticalStackLayout Spacing="10">

				<!-- Grid da quantidade de pessoas -->
				<Grid RowDefinitions="Auto, Auto" 
					  ColumnDefinitions="*, *, 2*">
					<Label Grid.Row="0" Grid.Column="0" Text="Adultos:"/>
					<Label Grid.Row="0" Grid.Column="1" Text="{Binding Value}"
						   BindingContext="{x:Reference stp_adultos}"/>
					<Stepper Grid.Row="0" Grid.Column="2" x:Name="stp_adultos" 
							 Minimum="0" Maximum="10" Increment="1"/>

					<Label Grid.Row="1" Grid.Column="0" Text="Crianças:"/>
					<Label Grid.Row="1" Grid.Column="1" Text="{Binding Value}"
					   BindingContext="{x:Reference stp_criancas}"/>
					<Stepper Grid.Row="1" Grid.Column="2" x:Name="stp_criancas" 
						 Minimum="0" Maximum="10" Increment="1"/>

				</Grid>

				<!-- Container com "Select" para pegar o quarto -->
				<Border Padding="10" StrokeShape="RoundRectangle 10">
					<VerticalStackLayout>

						<Label Text="Selecione sua Suíte:" />
						<Picker x:Name="pck_quarto" Title="Selecione sua Acomodação"
								ItemDisplayBinding="{Binding NomeComPreco}"/>

					</VerticalStackLayout>
				</Border>

				<!-- Container com "select" para pegar as datas de entrada e saída -->
				<Border Padding="10" StrokeShape="{RoundRectangle CornerRadius=10}">

					<VerticalStackLayout Spacing="10" >

						<Label Text="Periodo de Estadia" />
						<HorizontalStackLayout>
							<Label Text="Check-in:" />
							<DatePicker x:Name="dtpck_checkin"
										DateSelected="dtpck_checkin_DateSelected"
										Format="dd/MM/yyyy" />
							
						</HorizontalStackLayout>


						<Label Text="Periodo de Estadia" />
						<HorizontalStackLayout>
							<Label Text="Check-out:" />
							<DatePicker x:Name="dtpck_checkout"
										Format="dd/MM/yyyy" />

						</HorizontalStackLayout>

					</VerticalStackLayout>
					
				</Border>

				<Button Text="Calcular Valor" Clicked="Button_Clicked" />
				

			</VerticalStackLayout>

		</Border>

	</VerticalStackLayout>

</ContentPage>